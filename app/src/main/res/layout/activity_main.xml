<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000"
    android:padding="32dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI VISION PRO"
        android:textColor="#00FF44"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="كشف الأعداء في الألعاب"
        android:textColor="#4A9A4A"
        android:textSize="14sp"
        android:layout_marginBottom="48dp" />

    <!-- Status card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1A0D"
        android:padding="20dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الحالة"
            android:textColor="#4A9A4A"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ متوقف"
            android:textColor="#888888"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Instructions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0A0A"
        android:padding="16dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="كيفية الاستخدام:"
            android:textColor="#00FF44"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. اضغط تشغيل الكشف\n2. امنح إذن الطبقة العلوية\n3. امنح إذن تسجيل الشاشة\n4. افتح لعبتك — سيظهر الكشف فوراً"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>

    <!-- Start button -->
    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="تشغيل الكشف"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#00CC44"
        android:layout_marginBottom="16dp" />

    <!-- Exit button -->
    <Button
        android:id="@+id/btnExit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="خروج"
        android:textColor="#888888"
        android:textSize="14sp"
        android:backgroundTint="#1A1A1A" />

</LinearLayout>
